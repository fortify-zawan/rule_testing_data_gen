{
  "benchmark_data": [
    {
      "label": "R01 — Structuring: high-frequency burst with low average transfer amount",
      "rule_desc": "Flag any account that makes 5 or more outbound transfers within a 7-day period where the average transfer amount is below $1,000",
      "rule": {
        "rule_type": "behavioral",
        "relevant_attributes": ["transaction_id", "send_amount"],
        "conditions": [
          {
            "attribute": "transaction_id",
            "operator": ">=",
            "value": 5,
            "aggregation": "count",
            "window": "7d",
            "logical_connector": "AND",
            "filter_attribute": null,
            "filter_operator": null,
            "filter_value": null,
            "derived_attributes": null,
            "derived_expression": null,
            "window_mode": null
          },
          {
            "attribute": "send_amount",
            "operator": "<",
            "value": 1000.0,
            "aggregation": "average",
            "window": "7d",
            "logical_connector": "AND",
            "filter_attribute": null,
            "filter_operator": null,
            "filter_value": null,
            "derived_attributes": null,
            "derived_expression": null,
            "window_mode": null
          }
        ],
        "raw_expression": "count(transaction_id[7d]) >= 5 AND average(send_amount[7d]) < 1000",
        "high_risk_countries": []
      }
    },
    {
      "label": "R02 — Structuring: many small transfers to one country, none exceeding threshold",
      "rule_desc": "Alert if a user sends at least 8 transactions to Mexico in the last 30 days and no single transaction to Mexico exceeds $1,000",
      "rule": {
        "rule_type": "behavioral",
        "relevant_attributes": ["transaction_id", "receive_country_code", "send_amount"],
        "conditions": [
          {
            "attribute": "transaction_id",
            "operator": ">=",
            "value": 8,
            "aggregation": "count",
            "window": "30d",
            "logical_connector": "AND",
            "filter_attribute": "receive_country_code",
            "filter_operator": "in",
            "filter_value": ["Mexico"],
            "derived_attributes": null,
            "derived_expression": null,
            "window_mode": null
          },
          {
            "attribute": "send_amount",
            "operator": "<=",
            "value": 1000.0,
            "aggregation": "max",
            "window": "30d",
            "logical_connector": "AND",
            "filter_attribute": "receive_country_code",
            "filter_operator": "in",
            "filter_value": ["Mexico"],
            "derived_attributes": null,
            "derived_expression": null,
            "window_mode": null
          }
        ],
        "raw_expression": "count(transaction_id[30d] to Mexico) >= 8 AND max(send_amount[30d] to Mexico) <= 1000",
        "high_risk_countries": ["Mexico"]
      }
    },
